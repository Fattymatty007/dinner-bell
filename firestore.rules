rules_version = '2';

// Each user may read and write only their own profile document.
// Publish these in the Firebase console: Firestore Database → Rules → paste → Publish.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
